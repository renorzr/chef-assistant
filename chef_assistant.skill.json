{
  "skill_id": "chef_assistant",
  "name": "Chef Assistant",
  "version": "0.1.0",
  "description": "Recipe CRUD, menu planning, hybrid semantic search, and Xiachufang import with human-intervention flow.",
  "base_url": "http://127.0.0.1:8000",
  "openapi_url": "http://127.0.0.1:8000/openapi.json",
  "auth": {
    "type": "none"
  },
  "actions": [
    {
      "name": "create_recipe",
      "method": "POST",
      "path": "/recipes"
    },
    {
      "name": "list_recipes",
      "method": "GET",
      "path": "/recipes"
    },
    {
      "name": "get_recipe",
      "method": "GET",
      "path": "/recipes/{recipe_id}",
      "path_params": ["recipe_id"]
    },
    {
      "name": "update_recipe",
      "method": "PUT",
      "path": "/recipes/{recipe_id}",
      "path_params": ["recipe_id"]
    },
    {
      "name": "delete_recipe",
      "method": "DELETE",
      "path": "/recipes/{recipe_id}",
      "path_params": ["recipe_id"]
    },
    {
      "name": "generate_menu",
      "method": "POST",
      "path": "/menu/generate"
    },
    {
      "name": "search_vector",
      "method": "POST",
      "path": "/recipes/search/vector"
    },
    {
      "name": "search_hybrid",
      "method": "POST",
      "path": "/recipes/search/hybrid"
    },
    {
      "name": "import_from_html",
      "method": "POST",
      "path": "/recipes/import/from-html"
    },
    {
      "name": "embedding_reindex",
      "method": "POST",
      "path": "/admin/embeddings/reindex"
    },
    {
      "name": "embedding_audit_status",
      "method": "GET",
      "path": "/admin/embeddings/audit"
    },
    {
      "name": "embedding_repair_missing",
      "method": "POST",
      "path": "/admin/embeddings/repair-missing"
    }
  ],
  "workflows": []
}
